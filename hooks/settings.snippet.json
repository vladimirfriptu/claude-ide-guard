{
  "hooks": {
    "PreToolUse": [
      { "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [ { "type": "command", "command": "~/.claude/hooks/ide-guard-write-pre.sh" } ] },
      { "matcher": "Read",
        "hooks": [ { "type": "command", "command": "~/.claude/hooks/ide-guard-read-pre.sh" } ] },
      { "matcher": "Bash",
        "hooks": [ { "type": "command", "command": "~/.claude/hooks/ide-guard-bash-pre.sh" } ] }
    ],
    "PostToolUse": [
      { "matcher": "Edit|Write|MultiEdit|NotebookEdit|Read",
        "hooks": [ { "type": "command", "command": "~/.claude/hooks/ide-guard-post.sh" } ] },
      { "matcher": "Bash",
        "hooks": [ { "type": "command", "command": "~/.claude/hooks/ide-guard-bash-post.sh" } ] }
    ]
  }
}
